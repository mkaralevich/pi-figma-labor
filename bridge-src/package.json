{
  "name": "figma-labor-bridge",
  "version": "0.1.0",
  "description": "Local bridge server between pi and the Figma plugin",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --outfile=../extensions/bridge.js",
    "dev": "node --watch --experimental-strip-types src/server.ts",
    "start": "node --experimental-strip-types src/server.ts"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.27.3",
    "typescript": "^5.7.0"
  }
}
